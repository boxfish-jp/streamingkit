{
  "name": "todo_viewer",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run build:title && npm run build:list && mv dist/title/title.html dist/title.html && mv dist/list/list.html dist/list.html && rm -r dist/title dist/list",
    "build:title": "PAGE=title vite build",
    "build:list": "PAGE=list vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo",
    "test": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@workspace/ui": "workspace:*",
    "todo_parser": "workspace:*",
    "socket_client": "workspace:*",
    "kit_models": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "globals": "^17.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
